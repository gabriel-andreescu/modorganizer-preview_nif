{
  "version": 4,
  "configurePresets": [
    {
      "name": "cmake-dev",
      "hidden": true,
      "warnings": {
        "dev": true,
        "deprecated": true
      }
    },
    {
      "name": "vcpkg",
      "hidden": true,
      "toolchainFile": "$env{VCPKG_ROOT}/scripts/buildsystems/vcpkg.cmake",
      "cacheVariables": {
        "VCPKG_MANIFEST_NO_DEFAULT_FEATURES": {
          "type": "BOOL",
          "value": "ON"
        }
      }
    },
    {
      "name": "vcpkg-dev",
      "hidden": true,
      "inherits": ["vcpkg"]
    },
    {
      "name": "vs2022-windows",
      "inherits": ["cmake-dev", "vcpkg-dev"],
      "generator": "Visual Studio 17 2022",
      "toolset": "v143",
      "architecture": {
        "strategy": "set",
        "value": "x64"
      },
      "binaryDir": "${sourceDir}/vsbuild",
      "installDir": "${sourceDir}/../../../install",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/EHsc /MP /W4",
        "CMAKE_PREFIX_PATH": {
          "type": "STRING",
          "value": "C:/Qt/6.7.3/msvc2019_64;${sourceDir}/../../cmake_common;${sourceDir}/../../../install/lib/cmake"
        },
        "VCPKG_TARGET_TRIPLET": {
          "type": "STRING",
          "value": "x64-windows-static-md"
        }
      }
    },
    {
      "name": "vs2022-windows-standalone",
      "inherits": "vs2022-windows",
      "cacheVariables": {
        "VCPKG_MANIFEST_FEATURES": {
          "type": "STRING",
          "value": "standalone"
        }
      }
    },
    {
      "name": "ninja-multi",
      "inherits": ["cmake-dev", "vcpkg-dev"],
      "generator": "Ninja Multi-Config",
      "binaryDir": "${sourceDir}/cmake-build-ninja-multi",
      "installDir": "${sourceDir}/../../../install",
      "cacheVariables": {
        "CMAKE_CXX_FLAGS": "/EHsc /MP /W4",
        "CMAKE_PREFIX_PATH": {
          "type": "STRING",
          "value": "C:/Qt/6.7.3/msvc2019_64;${sourceDir}/../../cmake_common;${sourceDir}/../../../install/lib/cmake"
        },
        "VCPKG_TARGET_TRIPLET": {
          "type": "STRING",
          "value": "x64-windows-static-md"
        }
      }
    },
    {
      "name": "ninja-multi-mo2-2.5.2",
      "inherits": "ninja-multi",
      "binaryDir": "${sourceDir}/cmake-build-2.5.2",
      "cacheVariables": {
        "MO2_UIBASE_INCLUDE_DIR": {
          "type": "PATH",
          "value": "${sourceDir}/mo2-abi/2.5.2/include"
        },
        "PREVIEW_NIF_PACKAGE_MO2_VERSION": {
          "type": "STRING",
          "value": "MO2-2.5.2"
        }
      }
    },
    {
      "name": "ninja-multi-mo2-2.5.3beta11",
      "inherits": "ninja-multi",
      "binaryDir": "${sourceDir}/cmake-build-2.5.3beta11",
      "cacheVariables": {
        "MO2_UIBASE_INCLUDE_DIR": {
          "type": "PATH",
          "value": "${sourceDir}/mo2-abi/2.5.3beta11/include"
        },
        "PREVIEW_NIF_PACKAGE_MO2_VERSION": {
          "type": "STRING",
          "value": "MO2-2.5.3beta11"
        }
      }
    }
  ],
  "buildPresets": [
    {
      "name": "vs2022-windows",
      "configurePreset": "vs2022-windows",
      "resolvePackageReferences": "on"
    },
    {
      "name": "vs2022-windows-standalone",
      "configurePreset": "vs2022-windows-standalone",
      "resolvePackageReferences": "on"
    },
    {
      "name": "ninja-multi-release",
      "configurePreset": "ninja-multi",
      "configuration": "Release",
      "resolvePackageReferences": "on"
    },
    {
      "name": "ninja-multi-relwithdebinfo",
      "configurePreset": "ninja-multi",
      "configuration": "RelWithDebInfo",
      "resolvePackageReferences": "on"
    },
    {
      "name": "ninja-multi-mo2-2.5.2-relwithdebinfo",
