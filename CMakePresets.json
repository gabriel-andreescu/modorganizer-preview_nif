      "configuration": "RelWithDebInfo",
      "resolvePackageReferences": "on"
    },
    {
      "name": "ninja-multi-mo2-2.5.3beta11-relwithdebinfo",
      "configurePreset": "ninja-multi-mo2-2.5.3beta11",
      "configuration": "RelWithDebInfo",
      "resolvePackageReferences": "on"
    },
    {
      "name": "package-ninja-multi-mo2-2.5.2-relwithdebinfo",
      "configurePreset": "ninja-multi-mo2-2.5.2",
      "configuration": "RelWithDebInfo",
      "targets": ["preview_nif_zip"],
      "resolvePackageReferences": "on"
    },
    {
      "name": "package-ninja-multi-mo2-2.5.3beta11-relwithdebinfo",
      "configurePreset": "ninja-multi-mo2-2.5.3beta11",
      "configuration": "RelWithDebInfo",
      "targets": ["preview_nif_zip"],
      "resolvePackageReferences": "on"
    }
  ]
}
